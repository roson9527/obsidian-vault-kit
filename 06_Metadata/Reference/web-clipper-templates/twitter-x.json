{
    "schemaVersion": "0.1.0",
    "name": "Twitter / X",
    "behavior": "create",
    "noteContentFormat": "**{{author}}** {{selector:article time?datetime|date:\"YYYY-MM-DD\"}}\n\n{{content}}",
    "properties": [
        {
            "name": "title",
            "value": "{{author}} - {{description|slice:0:80}}",
            "type": "text"
        },
        {
            "name": "type",
            "value": "reference",
            "type": "text"
        },
        {
            "name": "source",
            "value": "{{url}}",
            "type": "text"
        },
        {
            "name": "author",
            "value": "{{author|split:\", \"|wikilink|join}}",
            "type": "multitext"
        },
        {
            "name": "published",
            "value": "{{published}}",
            "type": "date"
        },
        {
            "name": "date_saved",
            "value": "{{date}}",
            "type": "date"
        },
        {
            "name": "description",
            "value": "{{description|slice:0:200}}",
            "type": "text"
        },
        {
            "name": "tags",
            "value": "clippings",
            "type": "multitext"
        }
    ],
    "triggers": [
        "https://x.com",
        "https://twitter.com"
    ],
    "noteNameFormat": "{{author|replace:\"@\":\"\"|safe_name}} - {{description|slice:0:50|safe_name}}",
    "path": "00_Inbox"
}
