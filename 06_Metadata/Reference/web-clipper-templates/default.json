{
    "schemaVersion": "0.1.0",
    "name": "Default",
    "behavior": "create",
    "noteContentFormat": "{{content}}",
    "properties": [
        {
            "name": "title",
            "value": "{{title}}",
            "type": "text"
        },
        {
            "name": "type",
            "value": "reference",
            "type": "text"
        },
        {
            "name": "source",
            "value": "{{url}}",
            "type": "text"
        },
        {
            "name": "author",
            "value": "{{author|split:\", \"|wikilink|join}}",
            "type": "multitext"
        },
        {
            "name": "published",
            "value": "{{published}}",
            "type": "date"
        },
        {
            "name": "date_saved",
            "value": "{{date}}",
            "type": "date"
        },
        {
            "name": "description",
            "value": "{{description|slice:0:200}}",
            "type": "text"
        },
        {
            "name": "tags",
            "value": "clippings",
            "type": "multitext"
        }
    ],
    "triggers": [],
    "noteNameFormat": "{{title|slice:0:60|safe_name}}",
    "path": "00_Inbox"
}
